{
  "entities": {
    "User": {
      "title": "User",
      "description": "User profile and role information",
      "type": "object",
      "properties": {
        "uid": { "type": "string" },
        "email": { "type": "string", "format": "email" },
        "fullName": { "type": "string" },
        "role": { "type": "string", "enum": ["admin", "kepala_sekolah", "guru", "wali_kelas", "bp_bk", "tu", "kurikulum", "humas", "perpustakaan"] },
        "nip": { "type": "string" },
        "rank": { "type": "string" },
        "workUnit": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["uid", "email", "fullName", "role"]
    },
    "Student": {
      "title": "Student",
      "description": "Student personal and academic record",
      "type": "object",
      "properties": {
        "nisn": { "type": "string" },
        "name": { "type": "string" },
        "birthPlace": { "type": "string" },
        "birthDate": { "type": "string", "format": "date" },
        "gender": { "type": "string", "enum": ["L", "P"] },
        "parentName": { "type": "string" },
        "parentPhone": { "type": "string" },
        "address": { "type": "string" },
        "extracurricular": { "type": "string" },
        "photoUrl": { "type": "string" },
        "healthHistory": { "type": "string" },
        "height": { "type": "number" },
        "weight": { "type": "number" },
        "isActive": { "type": "boolean" },
        "classId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["nisn", "name", "gender", "isActive"]
    },
    "Class": {
      "title": "Class",
      "description": "Classroom/Rombel information",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "academicYear": { "type": "string" },
        "homeroomTeacherId": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["name", "academicYear", "homeroomTeacherId"]
    },
    "Attendance": {
      "title": "Attendance",
      "description": "Daily student attendance record",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "classId": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "status": { "type": "string", "enum": ["hadir", "sakit", "izin", "alpa"] },
        "notes": { "type": "string" },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["studentId", "classId", "date", "status"]
    },
    "Grade": {
      "title": "Grade",
      "description": "Student academic grade",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "subjectId": { "type": "string" },
        "classId": { "type": "string" },
        "type": { "type": "string", "enum": ["harian", "tugas", "uts", "uas"] },
        "score": { "type": "number" },
        "notes": { "type": "string" },
        "date": { "type": "string", "format": "date" },
        "createdBy": { "type": "string" }
      },
      "required": ["studentId", "subjectId", "classId", "type", "score"]
    },
    "Behavior": {
      "title": "Behavior",
      "description": "Student behavior record (reward/violation)",
      "type": "object",
      "properties": {
        "studentId": { "type": "string" },
        "type": { "type": "string", "enum": ["reward", "violation"] },
        "title": { "type": "string" },
        "description": { "type": "string" },
        "points": { "type": "number" },
        "date": { "type": "string", "format": "date" },
        "createdBy": { "type": "string" }
      },
      "required": ["studentId", "type", "title", "points"]
    },
    "AdminMessage": {
      "title": "AdminMessage",
      "description": "Messages sent to administrator",
      "type": "object",
      "properties": {
        "senderId": { "type": "string" },
        "senderName": { "type": "string" },
        "senderEmail": { "type": "string" },
        "subject": { "type": "string" },
        "message": { "type": "string" },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["senderId", "senderName", "senderEmail", "subject", "message", "status"]
    },
    "Event": {
      "title": "Event",
      "description": "School events, deadlines, and calendar items",
      "type": "object",
      "properties": {
        "title": { "type": "string" },
        "description": { "type": "string" },
        "startDate": { "type": "string", "format": "date-time" },
        "endDate": { "type": "string", "format": "date-time" },
        "type": { "type": "string", "enum": ["event", "deadline", "holiday"] },
        "createdBy": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["title", "startDate", "type"]
    },
    "Notification": {
      "title": "Notification",
      "description": "In-app notifications for users",
      "type": "object",
      "properties": {
        "userId": { "type": "string" },
        "title": { "type": "string" },
        "message": { "type": "string" },
        "type": { "type": "string", "enum": ["info", "warning", "success", "error"] },
        "status": { "type": "string", "enum": ["unread", "read"] },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["userId", "title", "message", "type", "status"]
    },
    "Schedule": {
      "title": "Schedule",
      "description": "Teacher teaching schedules",
      "type": "object",
      "properties": {
        "teacherId": { "type": "string" },
        "subject": { "type": "string" },
        "classId": { "type": "string" },
        "day": { "type": "string", "enum": ["Senin", "Selasa", "Rabu", "Kamis", "Jumat", "Sabtu"] },
        "startTime": { "type": "string" },
        "endTime": { "type": "string" },
        "createdAt": { "type": "string", "format": "date-time" }
      },
      "required": ["teacherId", "subject", "classId", "day", "startTime", "endTime"]
    }
  },
  "firestore": {
    "/users/{uid}": { "schema": "User", "description": "User profiles" },
    "/students/{studentId}": { "schema": "Student", "description": "Student records" },
    "/classes/{classId}": { "schema": "Class", "description": "Class definitions" },
    "/attendances/{attendanceId}": { "schema": "Attendance", "description": "Attendance records" },
    "/grades/{gradeId}": { "schema": "Grade", "description": "Grade records" },
    "/behaviors/{behaviorId}": { "schema": "Behavior", "description": "Behavior records" },
    "/admin_messages/{messageId}": { "schema": "AdminMessage", "description": "Messages for admin" },
    "/events/{eventId}": { "schema": "Event", "description": "School events" },
    "/notifications/{notificationId}": { "schema": "Notification", "description": "User notifications" },
    "/schedules/{scheduleId}": { "schema": "Schedule", "description": "Teacher schedules" }
  }
}
